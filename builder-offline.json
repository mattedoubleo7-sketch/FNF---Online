{
  "appId": "com.matth.fnfbrowserjam.offline",
  "productName": "FNF Browser Jam Offline",
  "extraMetadata": {
    "main": "main.js",
    "fnfDefaultDesktopMode": "offline"
  },
  "files": [
    "main.js",
    "preload.js",
    "desktop-mode.js",
    "remote-server-url.txt",
    "server.js",
    "downloads.html",
    "FNF - Online.html",
    "FNF - Offline.html",
    "online-mode.js",
    "sprite-data.js",
    "sporting-chart.js",
    "perseverance-data.js",
    "assets/**/*",
    "*.ogg",
    "package.json",
    "broken-reality-data.js",
    "broken-reality-mode.js",
    "broken-reality-fix.js",
    "broken-reality-soul-data.js",
    "*.mp4",
    "auto-update.js",
    "challenge-edd-data.js",
    "challenge-edd-mode.js",
    "challenge-edd-bf-data.js"
  ],
  "directories": {
    "output": "dist-offline"
  },
  "win": {
    "target": [
      "nsis"
    ],
    "artifactName": "FNF-Browser-Jam-offline-1.0.0-portable.${ext}",
    "signAndEditExecutable": false,
    "verifyUpdateCodeSignature": false,
    "icon": "assets/bf-logo-256.png"
  },
  "npmRebuild": false,
  "icon": "assets/bf-logo-256.png",
  "publish": [
    {
      "provider": "generic",
      "url": "https://github.com/mattedoubleo7-sketch/FNF---Online/releases/download/ONLINE"
    }
  ],
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false,
    "artifactName": "FNF-Browser-Jam-offline-1.0.0-portable.${ext}"
  }
}
